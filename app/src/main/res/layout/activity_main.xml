<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/color_background">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_launcher_foreground"
        android:layout_marginBottom="24dp" />

    <MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/color_primary"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LSPosed 游戏修改模块"
        android:textSize="14sp"
        android:textColor="@color/color_muted"
        android:layout_marginBottom="48dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_grant_permission"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="授予悬浮窗权限"
        android:textAllCaps="false"
        app:backgroundTint="@color/color_primary"
        app:cornerRadius="8dp"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_open_settings"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="打开应用设置"
        android:textAllCaps="false"
        app:strokeColor="@color/color_border"
        app:cornerRadius="8dp"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_start_service"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="启动模块"
        android:textAllCaps="false"
        app:backgroundTint="@color/color_success"
        app:cornerRadius="8dp" />

</LinearLayout>
