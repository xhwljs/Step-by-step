<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/scrim">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="16dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/card_background_dark">

            <!-- Title Bar -->
            <LinearLayout
                android:id="@+id/title_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="16dp">

                <MaterialTextView
                    android:id="@+id/tv_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/app_name"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_foreground"
                    android:fontFamily="sans-serif-medium" />

                <ImageView
                    android:id="@+id/btn_theme"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_theme"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/action_switch_theme" />

                <ImageView
                    android:id="@+id/btn_minimize"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_minimize"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="最小化" />

                <ImageView
                    android:id="@+id/btn_close"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_close"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="关闭" />

            </LinearLayout>

            <!-- Theme Color Selector -->
            <LinearLayout
                android:id="@+id/theme_color_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp"
                android:visibility="gone"
                android:layout_marginBottom="12dp">

                <MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="主题色："
                    android:textColor="@color/color_foreground"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp" />

            </LinearLayout>

            <!-- Start Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_modify"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/action_start_modify"
                android:textAllCaps="false"
                app:backgroundTint="@color/color_primary"
                app:cornerRadius="8dp"
                android:layout_marginBottom="16dp" />

            <!-- Island Mode Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_island_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_background_dark"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color_border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <MaterialTextView
                        android:id="@+id/tv_island_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_island_mode"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_foreground"
                        android:drawableStart="@drawable/ic_island"
                        android:drawablePadding="8dp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <MaterialTextView
                            android:id="@+id/tv_island_refresh_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/feature_infinite_refresh"
                            android:textColor="@color/color_foreground"
                            android:textSize="14sp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_island_refresh"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <MaterialTextView
                            android:id="@+id/tv_island_skill_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/feature_infinite_skill"
                            android:textColor="@color/color_foreground"
                            android:textSize="14sp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_island_skill"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Main Level Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_main_level"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_background_dark"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color_border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <MaterialTextView
                        android:id="@+id/tv_main_level_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_main_mode"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_foreground"
                        android:drawableStart="@drawable/ic_main_level"
                        android:drawablePadding="8dp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <MaterialTextView
                            android:id="@+id/tv_main_level_refresh_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/feature_infinite_refresh"
                            android:textColor="@color/color_foreground"
                            android:textSize="14sp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_main_level_refresh"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <MaterialTextView
                            android:id="@+id/tv_main_level_skill_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/feature_infinite_skill"
                            android:textColor="@color/color_foreground"
                            android:textSize="14sp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_main_level_skill"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Tribe Boss Card (预留) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_tribe_boss"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_background_dark"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color_border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <MaterialTextView
                        android:id="@+id/tv_tribe_boss_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_tribe_boss_mode"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_muted"
                        android:drawableStart="@drawable/ic_tribe_boss"
                        android:drawablePadding="8dp"
                        android:layout_marginBottom="12dp" />

                    <MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="功能开发中..."
                        android:textColor="@color/color_muted"
                        android:textSize="13sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Logs Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_logs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_background_dark"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color_border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <MaterialTextView
                            android:id="@+id/tv_logs_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/title_logs"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_foreground"
                            android:drawableStart="@drawable/ic_logs"
                            android:drawablePadding="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_copy_logs"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/action_copy_logs"
                            android:textSize="12sp"
                            android:textColor="@color/color_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_clear_logs"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/action_clear_logs"
                            android:textSize="12sp"
                            android:textColor="@color/color_destructive" />

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/log_recycler_view"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:background="@color/color_background"
                        android:padding="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</FrameLayout>
